# =============================================================
# 环境变量模板 — 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 这些变量用于 application-prod.yml 中的 ${...} 占位符
# =============================================================

# Spring profile: dev (本地开发) 或 prod (正式环境)
SPRING_PROFILES_ACTIVE=dev

# MySQL 配置 (prod profile 使用)
MYSQL_URL=jdbc:mysql://localhost:3306/travel_system?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password_here

# Elasticsearch 配置
ES_URIS=http://localhost:9200
ES_REPOSITORIES_ENABLED=true

# GraphHopper 路由配置
GRAPHHOPPER_ENABLED=true
GRAPHHOPPER_OSM_FILE=data/osm/china-260415.osm.pbf
GRAPHHOPPER_GRAPH_LOCATION=data/graph-cache

# 服务端口
SERVER_PORT=8080
