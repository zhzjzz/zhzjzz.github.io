<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.travel.system.mapper.RoadNodeMapper">

    <!-- 查询全部道路节点 -->
    <select id="findAll" resultType="com.travel.system.model.RoadNode">
        SELECT * FROM road_node
    </select>

    <!-- 按 ID 查询单个道路节点 -->
    <select id="findById" parameterType="long" resultType="com.travel.system.model.RoadNode">
        SELECT * FROM road_node WHERE id = #{id}
    </select>

    <!-- 插入新道路节点 -->
    <insert id="insert" parameterType="com.travel.system.model.RoadNode"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO road_node(name, node_type, latitude, longitude)
        VALUES(#{name}, #{nodeType}, #{latitude}, #{longitude})
    </insert>

    <!-- 更新已有道路节点 -->
    <update id="update" parameterType="com.travel.system.model.RoadNode">
        UPDATE road_node
        SET name = #{name},
            node_type = #{nodeType},
            latitude = #{latitude},
            longitude = #{longitude}
        WHERE id = #{id}
    </update>

</mapper>
