<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.travel.system.mapper.ItineraryMapper">

    <!-- 查询全部行程记录 -->
    <select id="findAll" resultType="com.travel.system.model.Itinerary">
        SELECT * FROM itinerary
    </select>

    <!-- 按 ID 查询单条行程 -->
    <select id="findById" parameterType="long" resultType="com.travel.system.model.Itinerary">
        SELECT * FROM itinerary WHERE id = #{id}
    </select>

    <!-- 插入新行程记录 -->
    <insert id="insert" parameterType="com.travel.system.model.Itinerary"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO itinerary(user_id, title, description, start_date, end_date)
        VALUES(#{userId}, #{title}, #{description}, #{startDate}, #{endDate})
    </insert>

    <!-- 更新已有行程记录 -->
    <update id="update" parameterType="com.travel.system.model.Itinerary">
        UPDATE itinerary
        SET user_id = #{userId},
            title = #{title},
            description = #{description},
            start_date = #{startDate},
            end_date = #{endDate}
        WHERE id = #{id}
    </update>

</mapper>
