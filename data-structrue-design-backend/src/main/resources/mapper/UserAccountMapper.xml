<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.travel.system.mapper.UserAccountMapper">

    <!-- 查询用户总数 -->
    <select id="count" resultType="long">
        SELECT COUNT(1) FROM user_account
    </select>

    <!-- 根据用户名查找用户 -->
    <select id="findByUsername" resultType="com.travel.system.model.UserAccount">
        SELECT * FROM user_account WHERE username = #{username}
    </select>

    <!-- 检查用户名是否存在 -->
    <select id="existsByUsername" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM user_account WHERE username = #{username})
    </select>

    <!-- 根据ID查找用户 -->
    <select id="findById" resultType="com.travel.system.model.UserAccount">
        SELECT * FROM user_account WHERE id = #{id}
    </select>

    <!-- 插入新用户 -->
    <insert id="insert" parameterType="com.travel.system.model.UserAccount"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_account(username, password_hash, display_name, interests)
        VALUES(#{username}, #{passwordHash}, #{displayName}, #{interests})
    </insert>

    <!-- 更新用户信息 -->
    <update id="update" parameterType="com.travel.system.model.UserAccount">
        UPDATE user_account
        SET username = #{username},
            password_hash = #{passwordHash},
            display_name = #{displayName},
            interests = #{interests}
        WHERE id = #{id}
    </update>

</mapper>
