# Environment template

# Spring Boot profile is optional. The default application.yml already uses SQLite.
SPRING_PROFILES_ACTIVE=dev

# SQLite/GeoPackage database path.
# Default: relative to backend project root, so run commands from data-structure-design-backend.
SQLITE_URL=jdbc:sqlite:data-structure-design-backend/data/tourism_system.gpkg

# Server port. Change this if 8080 is occupied.
SERVER_PORT=8080

