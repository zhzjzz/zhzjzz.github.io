# Environment template
# Unified reference file:
# ../deploy.api.env.example

# Spring Boot profile is optional. The default application.yml already uses SQLite.
SPRING_PROFILES_ACTIVE=dev

# SQLite/GeoPackage database path.
# Default: relative to backend project root, so run commands from data-structure-design-backend.
SQLITE_URL=jdbc:sqlite:D:/codex-deps/zhzjzz.github.io/data/tourism_system.gpkg

# Server port. Change this if 8080 is occupied.
SERVER_PORT=8080

# AMap Web Service key for backend food search/import.
# You can reuse the same key as VITE_AMAP_KEY at first, then split them for production.
AMAP_KEY=your-amap-web-service-key
AMAP_FOOD_CITY=Beijing

# OpenAI-compatible LLM provider for the travel service Agent and guide import.
# Keep the real API key in your local shell, local .env, or deployment environment only.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=90

# Backward-compatible SiliconFlow names still work when LLM_* variables are unset.
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Optional AIGC image generation for diary-related features.
AIGC_IMAGE_API_URL=https://api.siliconflow.cn/v1/images/generations
AIGC_IMAGE_API_KEY=your-aigc-image-api-key
AIGC_IMAGE_MODEL=Kwai-Kolors/Kolors
