# Unified API deployment template
# Fill this file once, then copy the needed values into:
# - data-structure-design-frontend/.env
# - data-structure-design-backend/.env

# Frontend -> backend
VITE_API_BASE_URL=https://sleet-mango-proponent.ngrok-free.dev/api
VITE_ASSET_BASE_URL=https://sleet-mango-proponent.ngrok-free.dev

# AMap Web / JS SDK
VITE_AMAP_KEY=7ee4ddc87c00043347a7524ee2a3db88
VITE_AMAP_SECRET=845020699f5dab0f389724dbe498d69d

# Optional backend-side AMap script usage
AMAP_KEY=your-amap-web-service-key
AMAP_FOOD_CITY=Beijing

# Backend LLM provider
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=90

# Backward-compatible SiliconFlow names
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# Diary AIGC image generation
AIGC_IMAGE_API_URL=https://api.siliconflow.cn/v1/images/generations
AIGC_IMAGE_API_KEY=your-aigc-image-api-key
AIGC_IMAGE_MODEL=Kwai-Kolors/Kolors

# Common runtime values often needed during deployment
SERVER_PORT=8080
SQLITE_URL=jdbc:sqlite:D:/codex-deps/zhzjzz.github.io/data/tourism_system.gpkg
SPRING_PROFILES_ACTIVE=dev
